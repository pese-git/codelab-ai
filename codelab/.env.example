# CodeLab Configuration
# =====================

# LLM Configuration
# -----------------
# Provider: openai, anthropic, mock
CODELAB_LLM_PROVIDER=openai

# API Key (универсальный для выбранного провайдера)
CODELAB_LLM_API_KEY=sk-your-key-here

# Base URL (опционально, для совместимых API)
# CODELAB_LLM_BASE_URL=https://api.openai.com/v1

# Model (default: gpt-4o)
CODELAB_LLM_MODEL=gpt-4o

# Temperature (default: 0.7)
CODELAB_LLM_TEMPERATURE=0.7

# Max tokens (default: 8192)
CODELAB_LLM_MAX_TOKENS=8192

# Server Configuration
# --------------------
CODELAB_PORT=8765
CODELAB_HOST=127.0.0.1
CODELAB_HOME=~/.codelab

# WebSocket Configuration
# -----------------------
# Максимальный размер входящего сообщения в байтах (default: 4 МБ)
# CODELAB_WS_MAX_MSG_SIZE=4194304

# Интервал heartbeat-пинга в секундах (default: 30.0)
# CODELAB_WS_HEARTBEAT_INTERVAL=30.0

# Logging
# -------
CODELAB_LOG_LEVEL=INFO

# Web UI (optional)
# -----------------
# Для Web UI требуется дополнительный пакет textual-web:
#   uv pip install codelab[web]
# или:
#   pip install textual-web
